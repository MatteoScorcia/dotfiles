// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
	"prettier": {
		"allowed": false,
		"parser": ""
	},
	"scroll_beyond_last_line": "off",
	"outline_panel": {
		"dock": "left"
	},
	"collaboration_panel": {
		"dock": "left"
	},
	"agent": {
		"dock": "right",
		"favorite_models": [],
		"model_parameters": []
	},
	"disable_ai": true,
	"inlay_hints": {
		"enabled": false
	},
	"minimap": {
		"show": "never"
	},
	"search": {
		"button": false,
		"case_sensitive": true
	},
	"status_bar": {
		"active_language_button": false,
		"cursor_position_button": false
	},
	"toolbar": {
		"breadcrumbs": true,
		"quick_actions": false,
		"selections_menu": false
	},
	"ui_font_family": "JetBrains Mono",
	"buffer_font_family": "JetBrains Mono",
	"buffer_font_features": {
		"calt": false,
		"liga": false
	},
	"ui_font_features": {
		"calt": false,
		"liga": false
	},
	"icon_theme": {
		"mode": "light",
		"light": "Catppuccin Macchiato",
		"dark": "Catppuccin Macchiato"
	},
	"scrollbar": {
		"show": "never"
	},
	"preview_tabs": {
		"enabled": false
	},
	"preferred_line_length": 120,
	"vertical_scroll_margin": 4,
	"cursor_blink": false,
	// --- LazyVim Core Experience ---
	"relative_line_numbers": "disabled",
	"format_on_save": "on",
	"document_symbols": "on",
	"which_key": {
		"enabled": true
	},
	"vim_mode": true,
	"vim": {
		"toggle_relative_line_numbers": false,
		"use_system_clipboard": "always",
		"gdefault": true
	},
	// --- Neo-tree style Project Panel ---
	"project_panel": {
		"dock": "left",
		"button": false,
		"scrollbar": {
			"show": "never"
		},
		"git_status_indicator": true,
		"diagnostic_badges": true
	},
	// --- ToggleTerm style Terminal ---
	"terminal": {
		"font_family": "JetBrains Mono",
		"working_directory": "current_file_directory",
		"font_features": {
			"calt": false,
			"liga": false
		}
	},
	"git": {
		"inline_blame": {
			"enabled": false,
			"delay_ms": 500
		}
	},
	// --- Lazygit style Git Panel ---
	"git_panel": {
		"button": true,
		"dock": "right",
		"show_count_badge": true,
		"file_icons": true
	},
	"ui_font_size": 18,
	"buffer_font_size": 18.0,
	"theme": {
		"mode": "dark",
		"light": "One Light",
		"dark": "Catppuccin Macchiato - No Italics"
	},
	"telemetry": {
		"diagnostics": false,
		"metrics": false
	},
	// --- Biome Language Settings ---
	"languages": {
		"Astro": {
			"formatter": {
				"language_server": {
					"name": "biome"
				}
			}
		},
		"CSS": {
			"formatter": {
				"language_server": {
					"name": "biome"
				}
			}
		},
		"GraphQL": {
			"formatter": {
				"language_server": {
					"name": "biome"
				}
			}
		},
		"HTML": {
			"formatter": {
				"language_server": {
					"name": "biome"
				}
			}
		},
		"JSON": {
			"formatter": {
				"language_server": {
					"name": "biome"
				}
			}
		},
		"JSONC": {
			"formatter": {
				"language_server": {
					"name": "biome"
				}
			}
		},
		"JSX": {
			"formatter": {
				"language_server": {
					"name": "biome"
				}
			}
		},
		"JavaScript": {
			"formatter": {
				"language_server": {
					"name": "biome"
				}
			}
		},
		"TSX": {
			"formatter": {
				"language_server": {
					"name": "biome"
				}
			}
		},
		"TypeScript": {
			"formatter": {
				"language_server": {
					"name": "biome"
				}
			}
		}
	}
}
